Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"psln", "[", 
    RowBox[{"\[Kappa]k_", ",", "\[Epsilon]k_"}], "]"}], ":=", 
   RowBox[{"NDSolveValue", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], "+", 
               RowBox[{"\[Kappa]", " ", 
                RowBox[{"Sin", "[", "\[CapitalDelta]", "]"}]}]}], ")"}], 
             RowBox[{"p", "[", "\[CapitalDelta]", "]"}]}], ",", 
            "\[CapitalDelta]"}], "]"}], "+", 
          RowBox[{
           RowBox[{"\[Epsilon]", "^", "2"}], " ", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"p", "[", "\[CapitalDelta]", "]"}], ",", 
             "\[CapitalDelta]", ",", "\[CapitalDelta]"}], "]"}]}]}], 
         "\[Equal]", "0"}], ",", 
        RowBox[{
         RowBox[{"p", "[", 
          RowBox[{"-", "\[Pi]"}], "]"}], "\[Equal]", 
         RowBox[{"p", "[", "\[Pi]", "]"}]}], ",", 
        RowBox[{
         RowBox[{"p", "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Kappa]", "\[Rule]", "\[Kappa]k"}], ",", 
        RowBox[{"\[Epsilon]", "\[Rule]", "\[Epsilon]k"}]}], "}"}]}], ",", "p",
      ",", "\[CapitalDelta]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f1", "=", 
   RowBox[{"psln", "[", 
    RowBox[{"1.5", ",", "0.5"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f2", "=", 
   RowBox[{"psln", "[", 
    RowBox[{"1.5", ",", "0.75"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f3", "=", 
   RowBox[{"psln", "[", 
    RowBox[{"1.5", ",", "1.25"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n1", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"f1", "[", "\[CapitalDelta]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[CapitalDelta]", ",", 
       RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n2", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"f2", "[", "\[CapitalDelta]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[CapitalDelta]", ",", 
       RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n3", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"f3", "[", "\[CapitalDelta]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[CapitalDelta]", ",", 
       RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"f1", "[", "\[CapitalDelta]", "]"}], "/", "n1"}], ",", 
     RowBox[{
      RowBox[{"f2", "[", "\[CapitalDelta]", "]"}], "/", "n2"}], ",", 
     RowBox[{
      RowBox[{"f3", "[", "\[CapitalDelta]", "]"}], "/", "n3"}]}], "}"}], ",", 
   
   RowBox[{"{", 
    RowBox[{"\[CapitalDelta]", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
