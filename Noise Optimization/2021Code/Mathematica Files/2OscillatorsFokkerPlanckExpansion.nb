Cell[BoxData[
 RowBox[{
  RowBox[{"RsqrNum", "[", 
   RowBox[{"\[Kappa]_", ",", "\[Epsilon]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "pf", "}"}], ",", 
    RowBox[{
     RowBox[{"pf", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"\[Kappa]", " ", 
                  RowBox[{"Sin", "[", "\[CapitalDelta]", "]"}]}]}], ")"}], 
               RowBox[{"p", "[", "\[CapitalDelta]", "]"}]}], ",", 
              "\[CapitalDelta]"}], "]"}], "+", 
            RowBox[{
             RowBox[{"\[Epsilon]", "^", "2"}], " ", 
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"p", "[", "\[CapitalDelta]", "]"}], ",", 
               "\[CapitalDelta]", ",", "\[CapitalDelta]"}], "]"}]}]}], 
           "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{"p", "[", 
            RowBox[{"-", "\[Pi]"}], "]"}], "\[Equal]", 
           RowBox[{"p", "[", "\[Pi]", "]"}]}], ",", 
          RowBox[{
           RowBox[{"p", "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}], ",", "p",
         ",", "\[CapitalDelta]"}], "]"}]}], ";", 
     RowBox[{
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"pf", "[", "\[CapitalDelta]", "]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"1", "/", "2"}], "+", 
           RowBox[{
            RowBox[{"1", "/", "2"}], 
            RowBox[{"Cos", "[", "\[CapitalDelta]", "]"}]}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", 
          RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}], "/", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"pf", "[", "\[CapitalDelta]", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[CapitalDelta]", ",", 
          RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}]}], "]"}]}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.821042602349482*^9, {3.8210426881368103`*^9, 3.8210427682094593`*^9}, {
