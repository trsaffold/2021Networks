Cell[BoxData[{
 RowBox[{
  RowBox[{"RsqApprox", "[", 
   RowBox[{"\[Epsilon]_", ",", "\[Kappa]_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "+", 
        RowBox[{
         RowBox[{"1", "/", "2"}], 
         RowBox[{"(", 
          FractionBox[
           RowBox[{"4", " ", 
            SuperscriptBox["\[Epsilon]", "2"], " ", "\[Kappa]", " ", 
            RowBox[{"(", 
             RowBox[{"2", "+", 
              RowBox[{"8", " ", 
               SuperscriptBox["\[Epsilon]", "4"]}], "+", 
              SuperscriptBox["\[Kappa]", "2"]}], ")"}]}], 
           RowBox[{
            RowBox[{"64", " ", 
             SuperscriptBox["\[Epsilon]", "8"]}], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "4"}], "+", 
               SuperscriptBox["\[Kappa]", "2"]}], ")"}], "2"], "+", 
            RowBox[{"16", " ", 
             SuperscriptBox["\[Epsilon]", "4"], " ", 
             RowBox[{"(", 
              RowBox[{"5", "+", 
               SuperscriptBox["\[Kappa]", "2"]}], ")"}]}]}]], ")"}]}]}], ",", 
       
       RowBox[{"\[Kappa]", "<", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "+", 
        RowBox[{
         RowBox[{"1", "/", "2"}], 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"\[Kappa]", "^", "2"}], "-", "1"}], "]"}], "/", 
          "\[Kappa]"}]}], " ", "-", 
        RowBox[{
         RowBox[{"\[Epsilon]", "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{"8", "\[Kappa]"}], ")"}]}]}], ",", 
       RowBox[{"\[Kappa]", "\[GreaterEqual]", "1"}]}], "}"}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rsqr", "[", "\[Kappa]_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"\[Kappa]", "\[LessEqual]", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"\[Kappa]", "+", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[Kappa]", "2"], "-", "1"}]]}], 
        RowBox[{"2", " ", "\[Kappa]"}]], ",", 
       RowBox[{"\[Kappa]", ">", "1"}]}], "}"}]}], "}"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.821022688596615*^9, 3.821022709170889*^9}, {
  3.8210227851256857`*^9, 3.8210229217760067`*^9}, {3.821024240906787*^9, 
