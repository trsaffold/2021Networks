        RowBox[{"0.5", ",", "\[Kappa]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Kappa]", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
