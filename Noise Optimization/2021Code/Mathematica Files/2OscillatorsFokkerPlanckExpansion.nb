Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"RsqrExtended", "[", 
   RowBox[{"\[Epsilon]_", ",", "\[Kappa]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"1", "/", "2"}], "+", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    RowBox[{"(", 
     FractionBox[
      RowBox[{"4", " ", 
       SuperscriptBox["\[Epsilon]", "2"], " ", "\[Kappa]", " ", 
       RowBox[{"(", 
        RowBox[{"2", "+", 
         RowBox[{"8", " ", 
          SuperscriptBox["\[Epsilon]", "4"]}], "+", 
         SuperscriptBox["\[Kappa]", "2"]}], ")"}]}], 
      RowBox[{
       RowBox[{"64", " ", 
        SuperscriptBox["\[Epsilon]", "8"]}], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "4"}], "+", 
          SuperscriptBox["\[Kappa]", "2"]}], ")"}], "2"], "+", 
       RowBox[{"16", " ", 
        SuperscriptBox["\[Epsilon]", "4"], " ", 
        RowBox[{"(", 
         RowBox[{"5", "+", 
          SuperscriptBox["\[Kappa]", "2"]}], ")"}]}]}]], 
     ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Rsqr", "[", "\[Kappa]", "]"}], ",", 
