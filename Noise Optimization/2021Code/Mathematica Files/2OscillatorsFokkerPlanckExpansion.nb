Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Fourier", " ", 
    RowBox[{"approach", "?"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"\[Kappa]", " ", 
          RowBox[{"Sin", "[", "\[CapitalDelta]", "]"}]}]}], ")"}], 
       RowBox[{"p", "[", "\[CapitalDelta]", "]"}]}], ",", "\[CapitalDelta]"}],
      "]"}], "+", 
    RowBox[{
     RowBox[{"\[Epsilon]", "^", "2"}], " ", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"p", "[", "\[CapitalDelta]", "]"}], ",", "\[CapitalDelta]", 
       ",", "\[CapitalDelta]"}], "]"}]}]}], "\[Equal]", "0"}]}]], "Input",
 CellChangeTimes->{{3.8210208913345118`*^9, 3.821020898135003*^9}, 
   3.82110094154771*^9},
 CellLabel->"In[14]:=",ExpressionUUID->"184178db-c7d2-4cf5-bce4-87b8bd1e09c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", " ", 
    RowBox[{"Cos", "[", "\[CapitalDelta]", "]"}], " ", 
    RowBox[{"p", "[", "\[CapitalDelta]", "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"\[Kappa]", " ", 
       RowBox[{"Sin", "[", "\[CapitalDelta]", "]"}]}]}], ")"}], " ", 
    RowBox[{
     SuperscriptBox["p", "\[Prime]",
      MultilineFunction->None], "[", "\[CapitalDelta]", "]"}]}], "+", 
   RowBox[{
    SuperscriptBox["\[Epsilon]", "2"], " ", 
    RowBox[{
     SuperscriptBox["p", "\[Prime]\[Prime]",
