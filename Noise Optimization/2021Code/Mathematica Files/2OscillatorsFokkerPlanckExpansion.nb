        RowBox[{"\[LeftAngleBracket]", 
         RowBox[{"R", "^", "2"}], "\[RightAngleBracket]"}]}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}], ",", "q"}], 
  "]"}]}], "Input",
